# 数据库（Vercel 部署建议使用 Neon 连接池 URL）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gmg?schema=public"

# JWT（生产环境务必更换为随机长字符串）
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Google OAuth（本地开发）
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/gmail/callback"

# Vercel 生产环境示例：
# GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/v1/gmail/callback"

# Gmail 搜索默认发件人
GMAIL_DEFAULT_SENDER="wenyang@ggtransport.in"
