generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Google Sheet 订单表（google_sheet 模块主表）
model google_sheet {
  id                                 BigInt                @id @default(autoincrement())
  container_type                     String                @default("40") @db.VarChar(10)
  weight                             Decimal?              @db.Decimal(12, 2)
  mbl                                String?               @db.VarChar(50)
  terminal                           String                @db.VarChar(50)
  customer                           String                @db.VarChar(100)
  container_no                       String                @unique(map: "uk_google_sheet_container_no") @db.VarChar(20)
  do_number                          String?               @db.VarChar(50)
  order_date                         DateTime?             @db.Date
  eta_date                           DateTime?             @db.Date
  operation_type                     operation_type        @default(fcl)
  delivery_location                  String?               @db.VarChar(200)
  lfd_date                           DateTime?             @db.Date
  pickup_date                        DateTime?             @db.Date
  forecast_window                    String?               @db.VarChar(50)
  empty_report_date                  DateTime?             @db.Date
  return_date                        DateTime?             @db.Date
  appointment_no                     String?               @db.VarChar(50)
  appointment_time                   DateTime?             @db.Timestamptz(6)
  warehouse_account                  String?               @db.VarChar(50)
  pickup_driver                      String?               @db.VarChar(50)
  return_driver                      String?               @db.VarChar(50)
  backend_delivery                   Boolean               @default(false)
  appointment_colleague              String?               @db.VarChar(50)
  remarks                            String?
  created_by                         BigInt
  updated_by                         BigInt?
  created_at                         DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime              @default(now()) @db.Timestamptz(6)
  deleted_at                         DateTime?             @db.Timestamptz(6)
  deleted_by                         BigInt?
  sort                               BigInt?
  users_google_sheet_created_byTousers users               @relation("google_sheet_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_google_sheet_deleted_byTousers users?              @relation("google_sheet_deleted_byTousers", fields: [deleted_by], references: [id], onUpdate: NoAction)
  users_google_sheet_updated_byTousers users?              @relation("google_sheet_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  container_parse_meta               container_parse_meta?
  google_sheet_history                 google_sheet_history[]

  @@index([created_at(sort: Desc)], map: "idx_google_sheet_created_at")
  @@index([customer], map: "idx_google_sheet_customer")
  @@index([eta_date], map: "idx_google_sheet_eta_date")
  @@index([lfd_date], map: "idx_google_sheet_lfd_date")
  @@index([pickup_driver], map: "idx_google_sheet_pickup_driver")
  @@index([terminal], map: "idx_google_sheet_terminal")
  @@map("google_sheet")
}

/// 货柜解析元数据（Gmail / 派送表），与 google_sheet 分离
model container_parse_meta {
  container_no     String       @id @db.VarChar(20)
  email_message_id String?      @db.VarChar(128)
  email_subject    String?      @db.VarChar(500)
  email_from       String?      @db.VarChar(255)
  email_date       DateTime?    @db.Timestamptz(6)
  attachment_name  String?      @db.VarChar(255)
  parse_status     parse_status @default(pending)
  error_message    String?
  is_correct       Boolean      @default(true)
  updated_at       DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  google_sheet     google_sheet @relation(fields: [container_no], references: [container_no], onDelete: Cascade, map: "fk_parse_meta_google_sheet")

  @@index([parse_status], map: "idx_container_parse_meta_status")
}

/// Google Sheet 记录版本历史（每次保存更新前写入快照）
model google_sheet_history {
  id             BigInt       @id @default(autoincrement())
  container_id   BigInt
  version        Int
  snapshot       Json
  operated_by    BigInt
  created_at     DateTime     @default(now()) @db.Timestamptz(6)
  google_sheet   google_sheet @relation(fields: [container_id], references: [id], onDelete: Cascade, map: "fk_google_sheet_history_sheet")
  users          users        @relation(fields: [operated_by], references: [id], onDelete: NoAction, map: "fk_google_sheet_history_operated_by")

  @@unique([container_id, version], map: "uk_google_sheet_history_container_version")
  @@index([container_id], map: "idx_google_sheet_history_container_id")
  @@index([created_at(sort: Desc)], map: "idx_google_sheet_history_created_at")
  @@map("google_sheet_history")
}

/// 货柜订单表（货柜管理主表，含 Gmail 解析字段）
model containers {
  id                                   BigInt                @id @default(autoincrement())
  container_type                       String                @default("40") @db.VarChar(10)
  weight                               Decimal?              @db.Decimal(12, 2)
  mbl                                  String?               @db.VarChar(50)
  vessel_name                          String?               @db.VarChar(30)
  voyage_no                            String?               @db.VarChar(30)
  terminal                             String                @default("-") @db.VarChar(50)
  customer                             String                @default("-") @db.VarChar(100)
  container_no                         String                @unique(map: "containers_container_no_key") @db.VarChar(20)
  pickup_company                       String?               @db.VarChar(100)
  return_company                       String?               @db.VarChar(100)
  do_number                            String?               @db.VarChar(50)
  order_date                           DateTime?             @db.Date
  eta_date                             DateTime?             @db.Date
  operation_type                       operation_type        @default(fcl)
  delivery_location                    String?               @db.VarChar(200)
  lfd_date                             DateTime?             @db.Date
  pickup_date                          DateTime?             @db.Date
  forecast_window                      String?               @db.VarChar(50)
  empty_report_date                    DateTime?             @db.Date
  return_date                          DateTime?             @db.Date
  transport_date                       DateTime?             @db.Date
  appointment_no                       String?               @db.VarChar(50)
  appointment_time                     DateTime?             @db.Timestamptz(6)
  warehouse_account                    String?               @db.VarChar(50)
  pickup_driver                        String?               @db.VarChar(50)
  return_driver                        String?               @db.VarChar(50)
  backend_delivery                     Boolean               @default(false)
  appointment_colleague                String?               @db.VarChar(50)
  is_correct                           Boolean               @default(true)
  remarks                              String?
  email_message_id                     String?               @db.VarChar(128)
  email_subject                        String?               @db.VarChar(500)
  email_from                           String?               @db.VarChar(255)
  email_date                           DateTime?             @db.Timestamptz(6)
  attachment_name                      String?               @db.VarChar(255)
  parse_status                         parse_status          @default(pending)
  error_message                        String?
  created_by                           BigInt
  updated_by                           BigInt?
  created_at                           DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime              @default(now()) @db.Timestamptz(6)
  deleted_at                           DateTime?             @db.Timestamptz(6)
  deleted_by                           BigInt?
  sort                                 BigInt?
  users_containers_created_byTousers   users                 @relation("containers_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_containers_deleted_byTousers   users?                @relation("containers_deleted_byTousers", fields: [deleted_by], references: [id], onUpdate: NoAction)
  users_containers_updated_byTousers     users?                @relation("containers_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  delivery_items                       delivery_items[]
  parse_logs                           parse_logs[]
  warehouse_summaries                  warehouse_summaries[]

  @@index([created_at(sort: Desc)], map: "idx_containers_created_at")
  @@index([customer], map: "idx_containers_customer")
  @@index([eta_date], map: "idx_containers_eta_date")
  @@index([lfd_date], map: "idx_containers_lfd_date")
  @@index([parse_status], map: "idx_containers_parse_status")
  @@index([pickup_driver], map: "idx_containers_pickup_driver")
  @@index([terminal], map: "idx_containers_terminal")
  @@map("containers")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model delivery_items {
  id                  BigInt     @id @default(autoincrement())
  container_no        String     @db.VarChar(20)
  customer_code       String?    @db.VarChar(50)
  fba_id              String?    @db.VarChar(100)
  reference_id        String?    @db.VarChar(100)
  cbm                 Decimal?   @db.Decimal(10, 2)
  weight              Decimal?   @db.Decimal(10, 2)
  carton_count        Int?
  warehouse_code      String?    @db.VarChar(50)
  delivery_method     String?    @db.VarChar(50)
  customer_note       String?
  actual_carton_count Int?
  pallet_count        Int?
  warehouse_note      String?
  is_warning          Boolean    @default(false)
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  containers          containers   @relation(fields: [container_no], references: [container_no], onDelete: Cascade, map: "fk_delivery_items_containers")

  @@index([container_no], map: "idx_delivery_items_container_no")
  @@index([fba_id], map: "idx_delivery_items_fba_id")
  @@index([warehouse_code], map: "idx_delivery_items_warehouse_code")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model parse_logs {
  id           BigInt     @id @default(autoincrement())
  container_no String     @db.VarChar(20)
  step         String     @db.VarChar(50)
  status       log_status
  message      String?
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  containers   containers   @relation(fields: [container_no], references: [container_no], onDelete: Cascade, map: "fk_parse_logs_containers")

  @@index([container_no], map: "idx_parse_logs_container_no")
  @@index([created_at(sort: Desc)], map: "idx_parse_logs_created_at")
  @@index([status], map: "idx_parse_logs_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id                                      BigInt       @id @default(autoincrement())
  username                                String       @unique(map: "uk_users_username") @db.VarChar(50)
  password_hash                           String       @db.VarChar(255)
  full_name                               String       @db.VarChar(100)
  phone                                   String?      @db.VarChar(20)
  email                                   String       @unique(map: "uk_users_email") @db.VarChar(100)
  role                                    user_role    @default(operator)
  is_enabled                              Boolean      @default(true)
  clerk_user_id                           String?      @unique(map: "uk_users_clerk_id") @db.VarChar(64)
  created_by                              BigInt?
  updated_by                              BigInt?
  created_at                              DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime     @default(now()) @db.Timestamptz(6)
  remarks                                 String?
  google_sheet_created_byTousers google_sheet[] @relation("google_sheet_created_byTousers")
  google_sheet_deleted_byTousers google_sheet[] @relation("google_sheet_deleted_byTousers")
  google_sheet_updated_byTousers google_sheet[] @relation("google_sheet_updated_byTousers")
  google_sheet_history                    google_sheet_history[]
  containers_created_byTousers            containers[] @relation("containers_created_byTousers")
  containers_deleted_byTousers            containers[] @relation("containers_deleted_byTousers")
  containers_updated_byTousers            containers[] @relation("containers_updated_byTousers")
  users_users_created_byTousers           users?       @relation("users_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  other_users_users_created_byTousers     users[]      @relation("users_created_byTousers")
  users_users_updated_byTousers           users?       @relation("users_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  other_users_users_updated_byTousers     users[]      @relation("users_updated_byTousers")
  customers_created                        customers[]  @relation("customers_created_by")
  customers_updated                        customers[]  @relation("customers_updated_by")

  @@index([is_enabled], map: "idx_users_is_enabled")
  @@index([role], map: "idx_users_role")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model warehouse_summaries {
  id             BigInt     @id @default(autoincrement())
  container_no   String     @db.VarChar(20)
  warehouse_code String     @db.VarChar(50)
  total_cartons  Int        @default(0)
  item_count     Int        @default(0)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  containers     containers   @relation(fields: [container_no], references: [container_no], onDelete: Cascade, map: "fk_warehouse_summaries_containers")

  @@unique([container_no, warehouse_code], map: "uk_warehouse_summaries_container_warehouse")
  @@index([container_no], map: "idx_warehouse_summaries_container_no")
}

enum log_status {
  success
  failed
  warning
}

enum operation_type {
  fcl @map("整柜")
  lcl @map("拆柜")
}

enum parse_status {
  pending
  parsing
  success
  failed
  partial_success
}

enum user_role {
  admin
  operator
  viewer
}

/// 订单表（订单管理）
model orders {
  id             Int       @id @default(autoincrement())
  container_no   String    @db.VarChar(20)
  operation_type String?   @db.VarChar(50)
  customer       String?   @db.VarChar(200)
  order_date     DateTime? @db.Date
  eta            DateTime? @db.Date
  pickup_date    DateTime? @db.Date
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  @@index([container_no], map: "idx_orders_container_no")
  @@index([created_at(sort: Desc)], map: "idx_orders_created_at")
  @@map("orders")
}

model customers {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100)
  contact     String?  @db.VarChar(50)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(100)
  address     String?  @db.VarChar(200)
  is_active   Boolean  @default(true)
  remarks     String?
  created_by  BigInt
  updated_by  BigInt?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)

  creator users? @relation("customers_created_by", fields: [created_by], references: [id], onUpdate: NoAction)
  updater users? @relation("customers_updated_by", fields: [updated_by], references: [id], onUpdate: NoAction)

  @@index([name], map: "idx_customers_name")
  @@index([created_at(sort: Desc)], map: "idx_customers_created_at")
}
