{
  "name": "gng_test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:init-prd": "prisma db execute --file prisma/sql/prd_5_3_init.sql --schema prisma/schema.prisma",
    "db:google-sheet": "prisma db execute --file prisma/sql/google_sheet.sql --schema prisma/schema.prisma",
    "db:google-sheet-cleanup": "prisma db execute --file prisma/sql/google_sheet_cleanup.sql --schema prisma/schema.prisma",
    "db:fix-autoincrement": "prisma db execute --file prisma/sql/fix_autoincrement_ids.sql --schema prisma/schema.prisma",
    "db:orders": "prisma db execute --file prisma/sql/orders.sql --schema prisma/schema.prisma",
    "db:parse-module": "prisma db execute --file prisma/sql/parse_module_v2.sql --schema prisma/schema.prisma",
    "db:ensure-parse": "prisma db execute --file prisma/sql/ensure_parse_schema.sql --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "import:orders": "tsx scripts/import-order-sheet.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^173.0.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
